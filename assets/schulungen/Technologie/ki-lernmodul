</footer>

<script>
  /* ── Navigation ── */
  function showSection(id) {
    document.querySelectorAll('.section').forEach(s => s.classList.remove('active'));
    document.querySelectorAll('.nav-tab').forEach(t => t.classList.remove('active'));
    document.getElementById(id).classList.add('active');
    event.currentTarget.classList.add('active');
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  /* ── Accordion ── */
  function toggleStrategy(el) {
    const wasOpen = el.classList.contains('open');
    document.querySelectorAll('.strategy-item').forEach(i => i.classList.remove('open'));
    if (!wasOpen) el.classList.add('open');
  }

  /* ── Quiz ── */
  let quizAnswers = {};

  function answer(btn, type, qId) {
    const qEl = document.getElementById(qId);
    if (qEl.dataset.answered) return;
    qEl.dataset.answered = '1';

    const opts = qEl.querySelectorAll('.quiz-opt');
    opts.forEach(o => { o.disabled = true; o.style.cursor = 'default'; });
    btn.classList.add(type);

    const fb = document.getElementById('fb' + qId.replace('q',''));
    fb.classList.add('show', type);

    quizAnswers[qId] = type === 'correct';
  }

  function showScore() {
    const total = 8;
    const correct = Object.values(quizAnswers).filter(Boolean).length;
    const pct = Math.round((correct / total) * 100);

    document.getElementById('score-text').textContent = correct + ' von ' + total + ' richtig (' + pct + '%)';

    let msg = '';
    if (pct >= 88) msg = 'Ausgezeichnet! Du hast die Konzepte sehr gut verstanden.';
    else if (pct >= 62) msg = 'Solide Kenntnisse! Lies die Abschnitte zu deinen Fehlerquellen nochmals.';
    else msg = 'Noch Luft nach oben – geh die Grundlagen und LLM-Abschnitte nochmal durch.';

    document.getElementById('score-msg').textContent = msg;
    document.getElementById('score-bar').style.width = pct + '%';

    const scoreEl = document.getElementById('quiz-score');
    scoreEl.style.display = 'block';
    scoreEl.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  }

  function resetQuiz() {
    quizAnswers = {};
    document.querySelectorAll('.quiz-question').forEach(q => {
      delete q.dataset.answered;
    });
    document.querySelectorAll('.quiz-opt').forEach(b => {
      b.disabled = false;
      b.style.cursor = 'pointer';
      b.classList.remove('correct', 'wrong');
    });
    document.querySelectorAll('.quiz-feedback').forEach(f => {
      f.classList.remove('show', 'correct', 'wrong');
    });
    document.getElementById('quiz-score').style.display = 'none';
  }

  /* ── Prompt Builder ── */
  const taskTemplates = {
    analyse: {
      role: 'Du bist ein erfahrener Analyst mit Expertise im Bereich [THEMA].',
      chain: 'Analysiere Schritt für Schritt: (1) Zusammenfassung, (2) Kernaussagen, (3) Risiken/Chancen, (4) Empfehlung.',
    },
    schreiben: {
      role: 'Du bist ein professioneller Autor mit Erfahrung in Finanz- und Geschäftstexten.',
      chain: 'Strukturiere deinen Text mit: Einleitung, Hauptteil (3 Punkte), Fazit.',
    },
    entscheidung: {
      role: 'Du bist ein objektiver Berater ohne Interessenkonflikte.',
      chain: 'Vergleiche systematisch: Kriterien definieren → Optionen bewerten → Empfehlung geben → Risiken nennen.',
    },
    daten: {
      role: 'Du bist ein Data Engineer mit Kenntnissen in Excel, Python und SQL.',
      chain: 'Gehe vor: Datenstruktur verstehen → Transformationslogik → Code/Formel → Erklärung.',
    },
    email: {
      role: 'Du bist ein erfahrener Kommunikationsprofi für geschäftliche Korrespondenz.',
      chain: 'Schreibe: Betreff → professionelle Anrede → Kernbotschaft → Handlungsaufruf → freundlicher Abschluss.',
    },
    code: {
      role: 'Du bist ein Senior-Entwickler mit Fokus auf sauberen, kommentierten Code.',
      chain: 'Vorgehen: Anforderung verstehen → Lösungsansatz nennen → Code schreiben → Erklärung → Testfälle.',
    },
  };

  const formatMap = {
    fliesstext: 'Antworte in klar strukturiertem Fließtext mit Absätzen.',
    stichpunkte: 'Nutze Stichpunkte und Aufzählungen für maximale Übersichtlichkeit.',
    tabelle: 'Erstelle eine Markdown-Tabelle als Ausgabe.',
    json: 'Antworte ausschließlich mit einem validen JSON-Objekt, ohne weitere Erklärung.',
    email: 'Schreibe im E-Mail-Format mit Betreff, Anrede, Text und Grußformel.',
  };

  const styleMap = {
    professionell: 'Ton: professionell und sachlich, geeignet für Geschäftskommunikation.',
    einfach: 'Ton: einfach und verständlich, ohne Fachjargon – auch Laien sollen es verstehen.',
    technisch: 'Ton: technisch präzise, für Experten – Fachbegriffe sind willkommen.',
    knapp: 'Ton: äußerst knapp – maximal 5 Sätze, kein Fülltext.',
  };

  function buildPrompt() {
    const task = document.getElementById('pb-task').value;
    const topic = document.getElementById('pb-topic').value.trim();
    const format = document.getElementById('pb-format').value;
    const style = document.getElementById('pb-style').value;
    const out = document.getElementById('pb-output');

    if (!task || !topic) {
      out.innerHTML = '<span class="placeholder">Wähle Aufgabentyp und gib dein Thema ein...</span>';
      return;
    }

    const tmpl = taskTemplates[task];
    const topicFilled = tmpl.role.replace('[THEMA]', topic);

    const prompt = topicFilled + '\n\n' +
      'Thema/Aufgabe: ' + topic + '\n\n' +
      tmpl.chain + '\n\n' +
      formatMap[format] + '\n' +
      styleMap[style];

    out.textContent = prompt;
  }

  function copyPrompt() {
    const text = document.getElementById('pb-output').textContent;
    if (text.includes('Wähle')) return;
    navigator.clipboard.writeText(text).then(() => {
      const btn = event.currentTarget;
      const orig = btn.textContent;
      btn.textContent = '✓ Kopiert';
      setTimeout(() => { btn.textContent = orig; }, 1500);
    });
  }

  function resetBuilder() {
    document.getElementById('pb-task').value = '';
    document.getElementById('pb-topic').value = '';
    document.getElementById('pb-format').value = 'fliesstext';
    document.getElementById('pb-style').value = 'professionell';
    document.getElementById('pb-output').innerHTML = '<span class="placeholder">Wähle Aufgabentyp und gib dein Thema ein...</span>';
  }
</script>
</body>
</html>
